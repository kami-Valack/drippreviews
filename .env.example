# URL pública deste servidor (usada em og:url, sitemap, canonical)
SITE_URL=http://localhost:3000

# API da loja DRIP
API_BASE_URL=https://api.drip.infinityfree.me/api

# Nome da loja (meta tags)
STORE_NAME=DRIP

# Moeda dos preços (centavos na API → ex: 2990 = 29,90 AOA)
CURRENCY=AOA

# Loja principal (redirect após preview). Use {id} para o ID do produto
STORE_PRODUCT_URL=https://store-eight-ashen.vercel.app/product/{id}

# Segundos até redirect automático para a loja
REDIRECT_DELAY_SECONDS=5

PORT=3000
